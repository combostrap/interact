{
  "name": "@combostrap/interact",
  "version": "0.1.0",
  "license": "FSL-1.1-ALv2",
  "type": "module",
  "description": "A React publication framework to create documentation where users can log in and interact with it",
  "bin": {
    "interact": "./dist/interact/cli/cli.js"
  },
  "repository": "https://github.com/combostrap/interact",
  "scripts": {
    "build": "tsc -p src/interact/tsconfig.json --listEmittedFiles",
    "check": "yarn check:cli && yarn check:resources",
    "check:cli": "tsc -p src/interact/tsconfig.json",
    "check:contrib": "tsc -p contrib/scripts/tsconfig.json",
    "check:resources": "tsc -p src/resources/tsconfig.json",
    "watch": "tsc --watch",
    "start": "ninteract start --confPath=apps/site",
    "site": "cd ../../gerardnico/com-gerardnico && ninteract start",
    "ssg": "ninteract build --confPath=apps/site",
    "preview": "ninteract preview --confPath=apps/site",
    "registry": "shadcn build --output apps/site/public/r"
  },
  "files": [
    "dist/interact/**/*",
    "src/**/*",
    "tsconfig.json"
  ],
  "exports": {
    "./types": "./src/types/index.d.ts",
    "./components/layouts/*": "./src/resources/components/layouts/*.tsx",
    "./components/partials/*": "./src/resources/components/partials/*.tsx",
    "./components/contexts/*": "./src/resources/components/contexts/*.tsx",
    "./components/heads/*": "./src/resources/components/heads/*.tsx",
    "./components/pages/*": "./src/resources/components/pages/*.tsx",
    "./components/*": "./src/resources/components/interact/*.tsx",
    "./vite/*": "./dist/interact/vite/*.js",
    "./markdown": "./src/resources/markdown/interactMarkdownProcessor.tsx",
    "./markdown/plugins/*": "./src/interact/markdown/plugins/*.ts",
    "./hooks/*": "./src/resources/hooks/*.ts",
    "./middlewares/*": "./src/resources/middlewares/*.tsx",
    "./config": "./src/interact/config/interactConfig.ts",
    "./deep-merge": "./src/interact/lib/deep-merge.ts",
    "./global.css": "./src/resources/styles/global.css",
    "./grid.css": "./src/resources/components/interact/grid.css"
  },
  "dependencies": {
    "@base-ui/react": "1.3.0",
    "@mdx-js/rollup": "3.1.1",
    "@realfavicongenerator/generate-favicon": "0.6.3",
    "@realfavicongenerator/image-adapter-node": "0.6.3",
    "@stefanprobst/rehype-extract-toc": "3.0.0",
    "@svgr/core": "8.1.0",
    "@svgr/plugin-jsx": "8.1.0",
    "@svgr/plugin-svgo": "8.1.0",
    "@tailwindcss/typography": "0.5.19",
    "@tailwindcss/vite": "4.2.2",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "bootstrap-icons": "1.13.1",
    "cac": "^7.0.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "debug": "4.4.3",
    "etag": "1.8.1",
    "glob": "13.0.6",
    "hastscript": "9.0.1",
    "lucide-react": "1.7.0",
    "mrmime": "2.0.1",
    "picocolors": "*",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "recma-mdx-is-mdx-component": "^2.0.0",
    "rehype-autolink-headings": "7.1.0",
    "rehype-parse": "^9.0.1",
    "rehype-react": "8.0.0",
    "rehype-remark": "^10.0.1",
    "rehype-slug": "6.0.0",
    "remark-frontmatter": "5.0.0",
    "remark-gfm": "4.0.1",
    "remark-mdx-frontmatter": "5.2.0",
    "rollup": "*",
    "rsc-html-stream": "0.0.7",
    "shadcn": "4.1.0",
    "sharp": "0.34.5",
    "srvx": "*",
    "svgo": "4.0.1",
    "tailwind-merge": "3.5.0",
    "tailwindcss": "4.2.2",
    "ts-node": "10.9.2",
    "tsx": "4.21.0",
    "tw-animate-css": "1.4.0",
    "vite": "8.0.13",
    "vite-plugin-inspect": "11.4.1",
    "vite-plugin-svgr": "4.5.0",
    "vitefu": "1.1.3",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@release-it/keep-a-changelog": "^7.1.0",
    "@types/debug": "4",
    "@types/etag": "1",
    "@types/hast": "3.0.4",
    "@types/mdast": "4.0.4",
    "@types/mdx": "2.0.13",
    "@types/node": "25.3.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "release-it": "20.2.0",
    "typescript": "5.9.3",
    "vitest": "4.1.0"
  },
  "packageManager": "yarn@4.12.0",
  "resolutions": {
    "sharp": "0.34.5",
    "@types/react": "19.2.14",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-server-dom-webpack": "19.2.6",
    "shadcn/zod": "^3",
    "zod": "4.3.6"
  },
  "publishConfig": {
    "access": "public"
  }
}
